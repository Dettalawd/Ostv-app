{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created." }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Bookmark": {
      "title": "Article Bookmark",
      "description": "Stores articles bookmarked by a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who bookmarked the article." },
        "articleId": { "type": "string", "description": "A unique ID for the article (e.g., hash of the URL)." },
        "title": { "type": "string", "description": "The article title." },
        "url": { "type": "string", "format": "uri", "description": "The article URL." },
        "source": { "type": "string", "description": "The news source." },
        "category": { "type": "string", "description": "The article category." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the article was bookmarked." }
      },
      "required": ["uid", "articleId", "title", "url", "source"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/bookmarks/{bookmarkId}": {
      "schema": "Bookmark",
      "description": "User's bookmarked articles."
    }
  }
}
